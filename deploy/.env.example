# Copy to .env on VPS: cp .env.example .env

# Docker Hub image (no build on VPS — pull only)
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# App
PORT=8080
ADMIN_PASSWORD=change-me-strong-password
CORS_ORIGIN=https://your-frontend-domain.com

# Database — use external Postgres or the postgres service below
POSTGRES_URL=postgres://mindex:mindex_secret@postgres:5432/mindex?sslmode=disable

# Postgres container (only if using bundled postgres service)
POSTGRES_USER=mindex
POSTGRES_PASSWORD=mindex_secret
POSTGRES_DB=mindex
